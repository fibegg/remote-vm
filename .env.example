# Web auth (gateway login form)
WEB_USER=admin
WEB_PASSWORD=changeme
# Random string used to sign session cookies. Generate with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
SESSION_SECRET=dev-only-change-me
COOKIE_NAME=rvm_session
COOKIE_MAX_AGE_SECONDS=28800

# Local HTTP works with the defaults below. In Fibe/Likeable HTTPS iframe deployments use:
# COOKIE_SECURE=true
# COOKIE_SAMESITE=none
# COOKIE_PARTITIONED=true
# COOKIE_NAME=__Host-rvm_session
COOKIE_SECURE=auto
COOKIE_SAMESITE=lax
COOKIE_PARTITIONED=false

# CSP/iframe policy. Fibe templates replace this with the active root domain.
CSP_MODE=enforce
FRAME_ANCESTORS=self
STATIC_CACHE_SECONDS=3600

# SSH credentials inside the VM (kept inside the docker network; never exposed to host)
SSH_USER=dev
SSH_PASSWORD=devpass

# Host port for the web terminal (bound to 127.0.0.1 only)
WEB_PORT=7681
BRANCH=main
